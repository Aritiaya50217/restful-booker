    {
      "name": "Auth",
      "item": [
        {
          "name": "login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Response status code is 200 \",function(){",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "})",
                  "",
                  "pm.test(\"check token exists\",function(){",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"token\")",
                  "})",
                  "",
                  "pm.test(\"token should exist and not be empty\",function(){",
                  "    var jsonData = pm.response.json(); ",
                  "    pm.expect(jsonData.token).to.not.be.empty;",
                  "})",
                  "",
                  "pm.test(\"token should be string\",function(){",
                  "var jsonData = pm.response.json(); ",
                  "pm.expect(jsonData.token).to.be.a(\"string\");",
                  "})",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.test(\"request method should be post\",function(){",
                  "    pm.expect(pm.request.method).to.eql(\"POST\")",
                  "});",
                  "",
                  "pm.test(\"request url is correct\",function(){",
                  "    pm.expect(pm.request.url.toString()).to.include(\"/auth\")",
                  "})",
                  "",
                  "pm.test(\"content-type should be application/json\",function(){",
                  "    pm.expect(pm.request.headers.get(\"Content-Type\")).to.eql(\"application/json\")",
                  "})",
                  "",
                  "let body = JSON.parse(pm.request.body.raw)",
                  "pm.test(\"request  body should contain username\",function(){",
                  "    pm.expect(body).to.have.property(\"username\");",
                  "})",
                  "",
                  "pm.test(\"request  body should contain password\",function(){",
                  "    pm.expect(body).to.have.property(\"password\");",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\" : \"admin\",\n    \"password\" : \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://restful-booker.herokuapp.com/auth",
              "protocol": "https",
              "host": [
                "restful-booker",
                "herokuapp",
                "com"
              ],
              "path": [
                "auth"
              ]
            }
          },
          "response": []
        }
      ]
